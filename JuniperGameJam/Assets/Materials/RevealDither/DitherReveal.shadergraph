{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "d5786ac3364040da822eb789f66debf8",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ParkerThreshold (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1159.1998291015625,
            "y": 566.3999633789063,
            "width": 247.9998779296875,
            "height": 117.5999755859375
        }
    },
    "m_Slots": [
        {
            "m_Id": "d0666ab70dfd4341b935a9c2d1acec99"
        },
        {
            "m_Id": "9d36cf6396f945b5959a89574f04aea2"
        },
        {
            "m_Id": "30ce1bf0fba84a4f818bb7ac522990f9"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ParkerThreshold",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float scale = max(0.0, floor(PatternScale));\nfloat2 scaledPixel = floor(PixelPosition / scale);\n\nint x = (int)fmod(scaledPixel.x, 3.0);\nint y = (int)fmod(scaledPixel.y, 3.0);\n\n$precision3 row0 = $precision3(0.23, 0.41, 0.29);\n$precision3 row1 = $precision3(0.41, 0.37, 0.01);\n$precision3 row2 = $precision3(0.29, 0.9, 0.47);\n\n$precision3 selectedRow =\n    y == 0 ? row0 :\n    y == 1 ? row1 :\n             row2;\n\nThreshold =\n    x == 0 ? selectedRow.x :\n    x == 1 ? selectedRow.y :\n             selectedRow.z;"
}

